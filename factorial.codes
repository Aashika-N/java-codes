import java.util.*;
public class Main{
public static void main(String []args){
int n=6;
int fact = factorial(n) ;
System.out.println("factorial of a number="+fact);
} 
    static int factorial (int k)
    {
    int ans = 1;
    for (int i=1; i<k;i++)
    {
   ans = ans*i;
}
   return ans;
}
}

